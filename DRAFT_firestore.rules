rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- USERS ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().email == existing().email;

      function isValidUser(data) {
        return data.keys().hasAll(['displayName', 'email', 'createdAt'])
          && data.keys().size() <= 6
          && data.displayName is string && data.displayName.size() <= 100
          && data.email is string && data.email.size() <= 100
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500));
      }

      // --- CHATS ---
      match /chats/{chatId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidChat(incoming())
          && incoming().userId == userId
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
        allow update: if isOwner(userId)
          && isValidChat(incoming())
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time;
        allow delete: if isOwner(userId);

        function isValidChat(data) {
          return data.keys().hasAll(['userId', 'updatedAt', 'createdAt'])
            && data.keys().size() <= 6
            && data.userId == request.auth.uid
            && (data.title == null || (data.title is string && data.title.size() <= 200))
            && (data.lastMessage == null || (data.lastMessage is string && data.lastMessage.size() <= 1000));
        }

        // --- MESSAGES ---
        match /messages/{messageId} {
          allow list: if isOwner(userId);
          allow get: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidMessage(incoming())
            && incoming().createdAt == request.time;
          
          function isValidMessage(data) {
            return data.keys().hasAll(['role', 'text', 'createdAt'])
              && data.keys().size() == 3
              && data.role in ['user', 'model']
              && data.text is string && data.text.size() <= 5000;
          }
        }
      }
    }
  }
}
